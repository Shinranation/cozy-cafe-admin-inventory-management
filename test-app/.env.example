# Uses envDir from `test-app/vite.config.js`, so this can also live in repo-root `.env`.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-public-key

# Required by current inventory_transactions insert when reference_id/cashier_id are NOT NULL.
VITE_TX_REFERENCE_ID=1
VITE_TX_CASHIER_ID=1
